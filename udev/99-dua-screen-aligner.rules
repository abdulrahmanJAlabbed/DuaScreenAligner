# DuaScreenAligner — udev rules for device access.
#
# These rules grant read/write access to the required input devices
# without running the daemon as root. Assigns devices to the "input"
# group, which the daemon user should be a member of.

# Allow access to /dev/uinput for virtual device creation.
# The daemon needs write access to create and manage the virtual mouse.
KERNEL=="uinput", GROUP="input", MODE="0660", TAG+="uaccess"

# Allow access to evdev mouse devices for reading raw input.
# More restrictive: only grant access to mouse event devices.
SUBSYSTEM=="input", ATTRS{name}!="DuaScreen Virtual Mouse", \
    KERNEL=="event[0-9]*", GROUP="input", MODE="0660", TAG+="uaccess"
