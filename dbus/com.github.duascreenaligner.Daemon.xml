<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
  "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">

<!--
  com.github.duascreenaligner.Daemon
  ===================================
  DBus interface contract between the Go daemon (server) and the
  GNOME Shell Extension (client). Exposed on the system bus at
  object path /com/github/duascreenaligner/Daemon.
-->
<node name="/com/github/duascreenaligner/Daemon">

  <interface name="com.github.duascreenaligner.Daemon">

    <!--
      SetLayout:
      Receives a JSON-encoded string describing the full monitor topology
      and per-monitor DPI configuration. The daemon parses this, rebuilds
      its internal transformation matrices, and applies changes immediately.

      @layout: JSON string matching the LayoutConfig schema.
      @success: true if layout was parsed and applied without error.
    -->
    <method name="SetLayout">
      <arg name="layout" type="s" direction="in"/>
      <arg name="success" type="b" direction="out"/>
    </method>

    <!--
      GetStatus:
      Returns the current operational state of the daemon.
      Possible values: "running", "paused", "error", "unconfigured".
    -->
    <method name="GetStatus">
      <arg name="status" type="s" direction="out"/>
    </method>

    <!--
      SetEnabled:
      Enables or disables cursor DPI correction without stopping the daemon.
      When disabled, events are passed through unmodified.

      @enabled: true to enable correction, false to passthrough.
      @success: true if the state change was applied.
    -->
    <method name="SetEnabled">
      <arg name="enabled" type="b" direction="in"/>
      <arg name="success" type="b" direction="out"/>
    </method>

    <!--
      ReloadDevice:
      Forces the daemon to re-scan /dev/input/ for the configured mouse
      device. Useful after hotplugging or device path changes.

      @success: true if a valid device was found and grabbed.
    -->
    <method name="ReloadDevice">
      <arg name="success" type="b" direction="out"/>
    </method>

    <!--
      GetLayout:
      Returns the currently active monitor layout configuration as a
      JSON-encoded string. Returns empty string if unconfigured.
    -->
    <method name="GetLayout">
      <arg name="layout" type="s" direction="out"/>
    </method>

    <!--
      ListDevices:
      Returns a JSON-encoded array of detected evdev mouse device paths
      and their human-readable names.
    -->
    <method name="ListDevices">
      <arg name="devices" type="s" direction="out"/>
    </method>

    <!--
      Version:
      Read-only property containing the daemon build version string.
    -->
    <property name="Version" type="s" access="read"/>

    <!--
      Enabled:
      Read-only property reflecting whether cursor correction is active.
    -->
    <property name="Enabled" type="b" access="read"/>

    <!--
      StatusChanged:
      Emitted whenever the daemon transitions between operational states.
      The signal payload is the new state string.
    -->
    <signal name="StatusChanged">
      <arg name="status" type="s"/>
    </signal>

    <!--
      LayoutApplied:
      Emitted after a new layout has been successfully parsed and the
      transformation matrices rebuilt.
    -->
    <signal name="LayoutApplied">
      <arg name="monitorCount" type="i"/>
    </signal>

  </interface>
</node>
